# MySQL配置
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=zscx
MYSQL_USER=zscx
MYSQL_PASSWORD=zscx123456
MYSQL_PORT=3306

# JimuReport 积木报表配置
JIMUREPORT_PORT=8085

# Web应用配置
WEB_PORT=3000
APP_NAME=房屋征收调查系统
# JWT密钥（必填！启动前必须设置一个随机密钥）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=please-change-this-secret-to-a-random-string-in-production
# Cookie Secure标志：true=仅HTTPS传输，false=HTTP/HTTPS都可用（默认false，内网HTTP部署时保持false）
COOKIE_SECURE=false

# 数据库连接（开发用）
DATABASE_URL=mysql://root:root123456@localhost:3306/zscx
