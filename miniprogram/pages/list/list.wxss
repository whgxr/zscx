.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  background: white;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.search-btn {
  background: #3b82f6;
  color: white;
  border-radius: 12rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  height: 72rpx;
}

.search-btn::after {
  border: none;
}

.record-list {
  padding-bottom: 120rpx;
}

.record-item {
  margin-bottom: 20rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-id {
  font-size: 24rpx;
  color: #6b7280;
  font-family: monospace;
}

.record-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-DRAFT {
  background: #f3f4f6;
  color: #6b7280;
}

.status-SUBMITTED {
  background: #dbeafe;
  color: #2563eb;
}

.status-REVIEWED {
  background: #d1fae5;
  color: #059669;
}

.status-REJECTED {
  background: #fee2e2;
  color: #dc2626;
}

.status-ARCHIVED {
  background: #e5e7eb;
  color: #6b7280;
}

.record-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-field {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.field-label {
  color: #6b7280;
  margin-right: 12rpx;
  min-width: 120rpx;
}

.field-value {
  color: #111827;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
}

.record-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #9ca3af;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #9ca3af;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #3b82f6;
  color: white;
  font-size: 48rpx;
  line-height: 100rpx;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.4);
}

.fab::after {
  border: none;
}
