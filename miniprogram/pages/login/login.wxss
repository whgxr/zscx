.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #3b82f6 0%, #60a5fa 100%);
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  background: white;
  border-radius: 32rpx;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.logo-icon {
  font-size: 72rpx;
}

.app-name {
  color: white;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.app-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
}

.login-form {
  background: white;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}
