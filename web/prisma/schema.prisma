// Prisma Schema for 房屋征收调查系统
// MySQL 5.7

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与权限系统 ====================

model User {
  id            Int          @id @default(autoincrement())
  username      String       @unique
  passwordHash  String
  realName      String
  phone         String?
  email         String?
  roleId        Int
  status        UserStatus   @default(ACTIVE)
  avatar        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     Int?

  // 关系
  role          Role         @relation(fields: [roleId], references: [id])
  tablePermissions TablePermission[]
  dataRecords      DataRecord[]      @relation("CreatedRecords")
  uploadedFiles    UploadedFile[]
  sessions         UserSession[]

  @@index([username])
  @@index([roleId])
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  label       String
  description String?
  canManageTables Boolean @default(false)
  canManageUsers Boolean @default(false)
  canManagePermissions Boolean @default(false)
  canManageTemplates Boolean @default(false)
  canViewLogs Boolean @default(false)
  canManageSettings Boolean @default(false)
  isSystem    Boolean      @default(false)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       User[]

  @@index([sortOrder])
}

enum DefaultRole {
  ADMIN
  MANAGER
  USER
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

// 用户登录会话
model UserSession {
  id          Int       @id @default(autoincrement())
  userId      Int
  token       String    @db.Text
  ipAddress   String?
  userAgent   String?
  deviceInfo  Json?
  isActive    Boolean   @default(true)
  lastActiveAt DateTime @default(now())
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isActive])
}

// 按数据表分配的权限
model TablePermission {
  id              Int           @id @default(autoincrement())
  userId          Int
  tableId         Int
  canView         Boolean       @default(true)
  canCreate       Boolean       @default(false)
  canEdit         Boolean       @default(false)
  canDelete       Boolean       @default(false)
  canExportExcel  Boolean       @default(false)
  canExportPdf    Boolean       @default(false)
  canPrint        Boolean       @default(false)
  canImport       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  user            User          @relation(fields: [userId], references: [id])
  table           DataTable     @relation(fields: [tableId], references: [id])

  @@unique([userId, tableId])
  @@index([tableId])
}

// ==================== 系统设置 ====================

model SystemSetting {
  id             Int          @id @default(autoincrement())
  key            String       @unique
  value          String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([key])
}

// 项目分类（3级分类）
model TableCategory {
  id        Int           @id @default(autoincrement())
  name      String        // 分类名称
  parentId  Int?          // 父分类ID
  level     Int           @default(1) // 层级：1,2,3
  sortOrder Int           @default(0)
  icon      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  parent    TableCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  TableCategory[] @relation("CategoryHierarchy")
  tables    DataTable[]

  @@index([parentId])
  @@index([sortOrder])
  @@index([level])
}

// 用户仪表盘配置
model UserDashboardConfig {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  config    Json      // 仪表盘配置（小组件、布局等）
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model DataTable {
  id                Int              @id @default(autoincrement())
  name              String           // 表名（英文标识）
  label             String           // 显示名称
  description       String?
  icon              String?          // 图标名
  categoryId        Int?             // 分类ID
  status            TableStatus      @default(ACTIVE)
  sortOrder         Int              @default(0)
  isDetailTable     Boolean          @default(false) // 是否为明细子表
  formLayoutConfig  Json?            // 表单布局配置（分组、列宽等）
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdBy         Int?

  // 关系
  fields         TableField[]
  records        DataRecord[]
  permissions    TablePermission[]
  files          UploadedFile[]
  exportTemplates ExportTemplate[]
  sharedExportTemplates ExportTemplate[] @relation("SharedTemplates")
  category       TableCategory?  @relation(fields: [categoryId], references: [id])

  @@unique([name])
  @@index([status])
  @@index([sortOrder])
  @@index([categoryId])
}

enum TableStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model TableField {
  id            Int              @id @default(autoincrement())
  tableId       Int
  name          String           // 字段名（英文标识）
  label         String           // 显示名称
  type          FieldType        // 字段类型
  required      Boolean          @default(false)
  unique        Boolean          @default(false)
  sortOrder     Int              @default(0)
  description   String?
  placeholder   String?          // 输入提示
  defaultValue  String?          // 默认值
  options       Json?            // 选项（用于select/radio/checkbox等）
  validation    Json?            // 验证规则 {min, max, pattern, ...}
  config        Json?            // 其他配置（如图片上传限制、关联表等）
  isSystem      Boolean          @default(false) // 是否系统字段（不可删除）
  showInList    Boolean          @default(true)  // 是否在列表显示
  showInForm    Boolean          @default(true)  // 是否在表单显示
  showInSearch  Boolean          @default(true)  // 是否可搜索
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  table         DataTable        @relation(fields: [tableId], references: [id])

  @@index([tableId])
  @@index([sortOrder])
}

enum FieldType {
  TEXT           // 单行文本
  TEXTAREA       // 多行文本
  NUMBER         // 数字
  INTEGER        // 整数
  FLOAT          // 小数
  DATE           // 日期
  DATETIME       // 日期时间
  SELECT         // 单选下拉
  RADIO          // 单选按钮
  MULTISELECT    // 多选
  CHECKBOX       // 复选框
  UPLOAD_IMAGE   // 图片上传
  UPLOAD_FILE    // 文件上传
  PHONE          // 手机号
  EMAIL          // 邮箱
  IDCARD         // 身份证号
  ADDRESS        // 地址
  MONEY          // 金额
  SWITCH         // 开关/是否
  RICHTEXT       // 富文本
  RELATION       // 关联其他表
  DETAIL_TABLE   // 明细表单
}

// ==================== 数据记录 ====================

model DataRecord {
  id            Int              @id @default(autoincrement())
  tableId       Int
  data          Json             // 动态字段数据
  status        RecordStatus     @default(DRAFT)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     Int?
  updatedBy     Int?

  // 关系
  table         DataTable        @relation(fields: [tableId], references: [id])
  creator       User?            @relation("CreatedRecords", fields: [createdBy], references: [id])
  files         UploadedFile[]

  @@index([tableId])
  @@index([createdAt])
  @@index([createdBy])
  @@index([status])
}

enum RecordStatus {
  DRAFT      // 草稿
  SUBMITTED  // 已提交
  REVIEWED   // 已审核
  REJECTED   // 已驳回
  ARCHIVED   // 已归档
}

// ==================== 文件上传 ====================

model UploadedFile {
  id            Int              @id @default(autoincrement())
  tableId       Int?
  recordId      Int?
  fieldName     String?
  originalName  String           // 原始文件名
  fileName      String           // 存储文件名
  filePath      String           // 文件路径
  fileSize      Int              // 文件大小（字节）
  mimeType      String           // MIME类型
  fileType      FileType         @default(OTHER)
  uploadedBy    Int?
  createdAt     DateTime         @default(now())

  // 关系
  table         DataTable?       @relation(fields: [tableId], references: [id])
  record        DataRecord?      @relation(fields: [recordId], references: [id])
  uploader      User?            @relation(fields: [uploadedBy], references: [id])

  @@index([tableId])
  @@index([recordId])
  @@index([createdAt])
}

enum FileType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  OTHER
}

// ==================== 操作日志 ====================

model OperationLog {
  id            Int              @id @default(autoincrement())
  userId        Int?
  action        String
  module        String
  tableId       Int?
  recordId      Int?
  detail        Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime         @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
}

// ==================== 错误日志 ====================

model ErrorLog {
  id            Int              @id @default(autoincrement())
  userId        Int?
  level         String           // ERROR, WARN, INFO
  module        String
  action        String
  message       String
  stackTrace    String?
  requestUrl    String?
  requestMethod String?
  requestParams Json?
  tableId       Int?
  recordId      Int?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime         @default(now())

  @@index([userId])
  @@index([level])
  @@index([module])
  @@index([createdAt])
}

// ==================== 导出模板 ====================

model ExportTemplate {
  id           Int              @id @default(autoincrement())
  tableId      Int
  name         String           // 模板名称
  type         ExportType       // 导出类型
  category     String           @default("EXPORT") // 模板分类：逗号分隔，如 "EXPORT,PRINT"
  description  String?
  config       Json             // 导出配置（字段、样式等）
  isDefault    Boolean          @default(false)
  isSystem     Boolean          @default(false) // 是否系统模板
  isShared     Boolean          @default(false) // 是否共享给其他表使用
  createdBy    Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  table        DataTable        @relation(fields: [tableId], references: [id])
  sharedTables DataTable[]      @relation("SharedTemplates")

  @@index([tableId])
  @@index([category])
  @@index([createdBy])
  @@index([isShared])
}

enum ExportType {
  STANDARD     // 标准列表
  CARD         // 卡片式
  GROUPED      // 分组汇总
  FORM         // 表单式（单条记录详情）
}

enum TemplateCategory {
  EXPORT  // 导出模板
  PRINT   // 打印模板
}
